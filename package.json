{
  "name": "yarn-tool",
  "version": "3.0.5",
  "description": "yarn/pnpm/lerna cli tool helper - support pnpm and yarn",
  "keywords": [
    "cli",
    "data deduplication",
    "dedupe",
    "deduplicate",
    "deduplication",
    "diff",
    "duplicated",
    "install",
    "lerna",
    "lockfile",
    "npm",
    "package",
    "package manager",
    "packages",
    "pnpm",
    "project",
    "tool",
    "workspace",
    "workspaces",
    "ws",
    "yarn",
    "yarn-tool",
    "yarn.lock",
    "pnpm-lock.yaml"
  ],
  "homepage": "https://github.com/bluelovers/yarn-tool#readme",
  "bugs": {
    "url": "https://github.com/bluelovers/yarn-tool/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluelovers/yarn-tool.git"
  },
  "license": "ISC",
  "author": "bluelovers",
  "main": "index.js",
  "bin": {
    "yarn-tool": "bin/yarn-tool.js",
    "yt": "bin/yt.js"
  },
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "scripts": {
    "test": "jest",
    "install:resetLockfile": "ts-node ./bin/yarn-tool install --reset-lockfile",
    "npm:publish": "node --run version:bump && npm publish",
    "version:bump": "ts-node ./bin/yarn-tool version",
    "prepublish:yarn:install": "echo ts-node ./bin/yarn-tool install",
    "prepublishOnly": "pnpm run ncu && node --run prepublish:yarn:install && pnpm run sort-package-json",
    "prepublishOnly_": "node --run prepublishOnly:update && node --run prepublishOnly:check-bin && pnpm run test",
    "prepublishOnly:check-bin": "ynpx --quiet @yarn-tool/check-pkg-bin",
    "prepublishOnly:lockfile": "ynpx --quiet sync-lockfile",
    "prepublishOnly:update": "pnpmn run ncu && pnpm run sort-package-json",
    "postpublish": "node --run postpublish:changelog && node --run postpublish:git:commit && node --run postpublish:git:tag && node --run postpublish:git:push",
    "postpublish:changelog": "ynpx --quiet @yarn-tool/changelog && git add ./CHANGELOG.md",
    "postpublish:git:commit": "git commit -m \"chore(release): publish\" . & echo postpublish:git:commit",
    "postpublish:git:push": "git push --follow-tags",
    "postpublish:git:tag": "ynpx --quiet @yarn-tool/tag",
    "bin:self": "ts-node ./bin/yarn-tool",
    "bin:self:js": "node ./bin/yarn-tool.js",
    "help": "ts-node ./bin/yarn-tool --help",
    "ncu": "ts-node ./bin/yarn-tool ncu -u",
    "sort-package-json": "ts-node ./bin/yarn-tool sort"
  },
  "dependencies": {
    "@bluelovers/fs-json": "^1.0.17",
    "@bluelovers/string-natural-compare": "^2.0.15",
    "@ts-type/package-dts": "^3.0.9",
    "@yarn-tool/detect-package-manager": "^1.0.8",
    "@yarn-tool/find-root": "^2.0.23",
    "@yarn-tool/fix-all": "^3.0.15",
    "@yarn-tool/ncu": "^3.0.8",
    "@yarn-tool/ncu-ws": "^2.0.10",
    "@yarn-tool/npm-package-arg-util": "^2.0.6",
    "@yarn-tool/pkg-deps-util": "^3.0.8",
    "@yarn-tool/require-resolve": "^4.0.7",
    "@yarn-tool/semver-diff": "^2.0.19",
    "@yarn-tool/static-file": "^3.0.15",
    "@yarn-tool/table": "^2.0.20",
    "@yarn-tool/update-notifier": "^1.0.46",
    "@yarn-tool/version-recommended": "^3.0.13",
    "@yarn-tool/write-package-json": "^1.0.15",
    "@yarn-tool/ws-scope": "^3.0.9",
    "@yarn-tool/yargs-util": "^1.0.15",
    "@yarn-tool/yarnlock": "^3.0.8",
    "@yarn-tool/yarnlock-fs": "^3.0.9",
    "@yarn-tool/yarnlock-ncu": "^3.0.10",
    "@yarn-tool/yarnlock-parse": "^3.0.9",
    "array-hyper-unique": "^2.1.8",
    "bluebird": "^3.7.2",
    "chalk": "^5.6.2",
    "create-yarn-workspaces": "^3.0.17",
    "crlf-normalize": "^1.0.20",
    "cross-spawn-extra": "^3.0.3",
    "debug-color2": "^1.3.2",
    "find-yarn-workspace-root2": "^1.2.53",
    "fs-extra": "^11.3.4",
    "inquirer": "^13.4.2",
    "npm-init2": "^3.0.17",
    "os-lang-locale": "^2.0.2",
    "os-locale": "^8.0.0",
    "package-json": "^10.0.1",
    "semver": "^7.7.4",
    "semver-utils": "^1.1.4",
    "sort-package-json": "^3.6.1",
    "sort-package-json3": "^3.0.10",
    "source-map-support": "^0.5.21",
    "string-natural-compare": "^3.0.1",
    "synp2": "^1.4.0",
    "terminal-link": "^5.0.0",
    "tslib": "^2.8.1",
    "upath2": "^3.1.23",
    "ws-pkg-list": "^3.0.9",
    "ws-root-spawn": "^1.0.52",
    "yargs": "<18 >=17.7.2",
    "yargs-parser": "^22.0.0",
    "yargs-unparser": "^2.0.0"
  },
  "devDependencies": {
    "@bluelovers/tsconfig": "^2.0.3",
    "@types/bluebird": "^3.5.42",
    "@types/deep-diff": "^1.0.5",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/semver": "^7.7.1",
    "@types/semver-utils": "^1.1.3",
    "@types/source-map-support": "^0.5.10",
    "@types/yargs": "^17.0.35",
    "@types/yargs-parser": "^21.0.3",
    "jest": "^30.3.0",
    "ts-type": "^3.0.13"
  }
}
